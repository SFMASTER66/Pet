generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Species {
  id                 Int                    @id @default(autoincrement())
  name               String                 @unique
  baseTimeMultiplier Float                  @default(1.0)
  pets               Pet[]
  matrices           ServicePricingMatrix[]
}

model Pet {
  id                String        @id @default(uuid())
  ownerId           String
  speciesId         Int
  merchantId        String
  breed             String
  name              String
  microchipNumber   String?       @unique
  status            PetStatus     @default(ACTIVE)
  gender            Gender        @default(UNKNOWN)
  isDesexed         Boolean       @default(false)
  dob               DateTime?
  behaviorTags      String[]
  behaviorNotes     String?
  loyaltyGroomCount Int           @default(0)
  weight            Float?
  appointments      Appointment[]
  merchant          Merchant      @relation(fields: [merchantId], references: [id])
  owner             User          @relation(fields: [ownerId], references: [id])
  species           Species       @relation(fields: [speciesId], references: [id])

  @@index([merchantId, name, status])
  @@index([merchantId, ownerId])
}

model Appointment {
  id                     String               @id @default(uuid())
  petId                  String
  groomerId              String?
  merchantId             String
  startTime              DateTime
  endTime                DateTime
  status                 AppointmentStatus    @default(PENDING)
  priceCentsAud          Int
  durationMinutes        Int
  isLoyaltyWaived        Boolean              @default(false)
  depositPaid            Boolean              @default(false)
  internalTags           String[]
  isCheckedIn            Boolean              @default(false)
  isReadyToPickup        Boolean              @default(false)
  bookedById             String
  notes                  String?
  servicePricingMatrixId Int
  bookedBy               User                 @relation("CreatedAppointments", fields: [bookedById], references: [id])
  groomer                Employee?            @relation(fields: [groomerId], references: [id])
  merchant               Merchant             @relation(fields: [merchantId], references: [id])
  pet                    Pet                  @relation(fields: [petId], references: [id])
  servicePricingMatrix   ServicePricingMatrix @relation(fields: [servicePricingMatrixId], references: [id])
  addOns                 AppointmentAddOn[]

  @@index([merchantId, startTime, groomerId])
}

model ServicePricingMatrix {
  id                    Int                @id @default(autoincrement())
  merchantId            String
  speciesId             Int?
  weightTier            WeightTier?
  coatType              CoatType?
  durationMinutes       Int
  priceCentsAud         Int
  name                  String
  isActive              Boolean            @default(true)
  appointments          Appointment[]
  appointmentsWithAddOn AppointmentAddOn[]
  merchant              Merchant           @relation(fields: [merchantId], references: [id])
  species               Species?           @relation(fields: [speciesId], references: [id])

  @@unique([merchantId, name, speciesId, weightTier, coatType])
  @@index([name, speciesId])
}

model User {
  id                  String            @id @default(uuid())
  merchantId          String
  email               String            @unique
  phoneNumber         String?           @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  role                UserRole          @default(CUSTOMER)
  countryCode         String            @default("AU")
  createdAt           DateTime          @default(now())
  activityLogs        ActivityLog[]
  createdAppointments Appointment[]     @relation("CreatedAppointments")
  employee            Employee?
  pets                Pet[]
  merchant            Merchant          @relation(fields: [merchantId], references: [id])
  waiverSignatures    WaiverSignature[]

  @@index([merchantId, createdAt])
  @@index([merchantId, name])
}

model Merchant {
  id               String                 @id @default(uuid())
  email            String                 @unique
  passwordHash     String
  businessName     String
  abn              String?
  stripeAccountId  String?                @unique
  createdAt        DateTime               @default(now())
  logoIcon         String?
  logoUrl          String?
  primaryColor     String                 @default("#FF05050E")
  tags             String[]               @default([])
  businessTags     Json?
  uiDictionary     Json?
  activityLogs     ActivityLog[]
  appointments     Appointment[]
  businessHours    BusinessHours[]
  employees        Employee[]
  pets             Pet[]
  rosterExceptions RosterException[]
  pricingMatrices  ServicePricingMatrix[]
  users            User[]
  waiverSignatures WaiverSignature[]
}

model Employee {
  id               String            @id @default(uuid())
  merchantId       String
  name             String
  avatarUrl        String?
  isActive         Boolean           @default(true)
  appointments     Appointment[]
  user             User              @relation(fields: [id], references: [id], onDelete: Cascade)
  merchant         Merchant          @relation(fields: [merchantId], references: [id])
  rosterExceptions RosterException[]

  @@index([merchantId])
}

model ActivityLog {
  id          String      @id @default(uuid())
  merchantId  String
  userId      String?
  category    LogCategory @default(ACTIVITY)
  moduleName  String
  action      String
  description String?
  ipAddress   String?
  userAgent   String?
  path        String?
  method      HttpMethod?
  metaData    Json?
  createdAt   DateTime    @default(now())
  merchant    Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])

  @@index([merchantId, createdAt])
  @@index([merchantId, category])
  @@index([merchantId, userId])
}

model AppointmentAddOn {
  appointmentId String
  matrixId      Int
  appointment   Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pricingMatrix ServicePricingMatrix @relation(fields: [matrixId], references: [id])

  @@id([appointmentId, matrixId])
}

model WaiverSignature {
  id           String   @id @default(uuid())
  merchantId   String
  ownerId      String
  ipAddress    String
  signedAt     DateTime @default(now())
  termsVersion String
  merchant     Merchant @relation(fields: [merchantId], references: [id])
  owner        User     @relation(fields: [ownerId], references: [id])

  @@unique([merchantId, ownerId])
}

model BusinessHours {
  id         Int      @id @default(autoincrement())
  merchantId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, dayOfWeek])
}

model RosterException {
  id         String   @id @default(uuid())
  employeeId String
  merchantId String
  date       DateTime
  startTime  String?
  endTime    String?
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
}

enum PetStatus {
  ACTIVE
  LOST
  ANGEL
}

enum UserRole {
  MERCHANT_ADMIN
  MERCHANT_STAFF
  CUSTOMER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED
}

enum WeightTier {
  XS
  S
  M
  L
  XL
  XXL
  ALL
}

enum CoatType {
  SHORT
  LONG_CURLY
  DOUBLE_A
  DOUBLE_B
  NONE
}

enum LogCategory {
  AUTH
  ACTIVITY
  SECURITY
}

enum HttpMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
}
